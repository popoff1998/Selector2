#GRUPO DE ORDENADORES CON MONITOR DE 17 PULGADAS
# --- XServer Options
#
# SCREEN_RESOLUTION       Screen resolutions available in the workstations
# SCREEN_COLOR_DEPTH      Number of bits per pixel (8,16,24)
# SCREEN_HORIZSYNC        Monitor horizontal sync frequency in Khz.
# SCREEN_VERTREFRESH      Monitor vertical refresh frecuency in Hz.
# SCREEN_X_FONT_SERVER    IP address or hostname of the font server for X
# MOUSE_PROTOCOL          Mouse protocol type (Microsoft, PS/2, etc.)
#                         (mouse is autodetected, use this only if it fails)
# MOUSE_DEVICE            Mouse device:  /dev/ttyS0 -> COM1
#                                   /dev/ttyS1 -> COM2
#                                   /dev/ttyS2 -> COM3
#                                   /dev/ttyS3 -> COM4
#                                   /dev/psaux -> PS/2 mouse port
#                                   /dev/input/mice -> USB mouse (needs USB package)
# MOUSE_RESOLUTION        Mouse resolution
# --- Advanced XServer Options - Experts Only
# X_DRIVER_NAME           Driver for X, this will override the autodetection scripts
# X_DRIVER_BUSID          Addditional options for driver
#Parametros de ahorro de energía
SCREEN_BLANK_TIME="0"
SCREEN_STANDBY_TIME="0"
SCREEN_SUSPEND_TIME="0"
SCREEN_OFF_TIME="0"
POWEROFF_TIME="0"
#SCREEN_RESOLUTION="1440x900 | *"
SCREEN_COLOR_DEPTH="24"
#SCREEN_HORIZSYNC="31-84 | *"
#SCREEN_VERTREFRESH="56-76 | 60 | 56 | 70 | 72 | 75"
SCREEN_HORIZSYNC="31-84 | *"
SCREEN_VERTREFRESH="75"
#NUEVA DE TONIN
#SCREEN_HORIZSYNC="60"
#SCREEN_VERTREFRESH="75"
MOUSE_DEVICE=/dev/input/mice
MOUSE_RESOLUTION=400
#MOUSE_ACCELERATION=1/2
#X_DRIVER_OPTION1="swcursor On"
#X_DRIVER_OPTION2="Xinerama Off"
# --- Advanced Options - Experts Only
#X_DRIVER_NAME="mga"
#X_DRIVER_BUSID="PCI:1:0:0"
# SERVIDOR DE SYSLOG-NG
SYSLOG_NG_SERVER=150.214.110.143
#PONER LA ZONA HORARIA BIEN Y SINCRONIZAR DE GONGORA
TIME_ZONE="Europe/Madrid"
NET_TIME_SERVER="150.214.110.1"
#DIRECCION DEL ICABROWSER
#EXPERIMENTAL MULTIPLES BROWSERS
ICA_DESIREDCOLOR="4"
#MONTAJE DEL REPOSITORIO /usr/local
#  SI LA NAS SE ESCACHARRA, COMENTAR LA PRIMERA LINEA Y DESCOMENTAR LA SEGUNDA
#NFSLOCAL_MOUNT="nfs:/TEMPORAL/TEMPORAL/TSDEV"
#NFSLOCAL_MOUNT="nfs:/TSEXP/TSEXP"
  NFSLOCAL_TYPE="-t nfs"
  NFSLOCAL_MOUNT="nfsunity-172-16.priv.uco.es:/TS3NEW/DEV"
#  NFSLOCAL_MOUNT="nfsvnx.uco.es:/TS3/3.2"
# El siguiente parámetro mete una ruta directa al NFS.
  NFSLOCAL_ROUTE=TRUE
#MONTAJE DEL HOME DEL USUARIO
#  ATENCION, EL FORZADO DE QUE MONTE POR SMB O NFS VA EN EL FICHERO DE CADA AULA
#  SI SE ROMPE LA NAS Y SE HABILITA PROVISIONALMENTE OTRO SERVIDOR, CAMBIAR LAS
#  LINEAS "NFS_HOME_SERVER y NFS_HOME_ROOT" APUNTANDO AL NUEVO SERVIDOR
SMB_HOME_SERVER="lucano"
NFS_HOME_SERVER="nfsunity-172-16.priv.uco.es"
NFS_HOME_ROOT="/HOMESNFS/HOMESNFS"
#Experimental cambios ICA
ICA_KEYBOARD=Spanish
X_NUMLOCK=ON
ICA_WFCLIENT_UseEUKS=2
#Experimental log permanente
#SYSLOG_NG_PERM=TRUE
#EXPERIMENTAL XORG_ACCEL_MODE
ENABLE_XORG_ACCEL_MODE="On"
XORG_ACCEL_MATCH=("Intel Corporation 2nd Generation" "Intel Corporation HD Graphics 530" "Intel Corporation UHD Graphics 630")
XORG_ACCEL_MODE=(uxa sna sna)
#Experimental 2018-2019
#ACTIVAR HDXAUDIO
HDXAUDIO=TRUE
EXPORTER_AGGREGATOR="http://sysdocker2.priv.uco.es:9090"
#########################
##   SESIONES
#########################

#TEMPLATE GROUP
MOUSE_PROTOCOL=IMPS/2
KEYBOARD_MAP=es
NET_TELNETD_ENABLED=ON
NET_REMOTE_ACCESS_FROM="150.214.0.0"
SYSLOG_SERVER=local
RECONNECT_PROMPT="On"
TIME_ZONE="Europe/Madrid"
SCREEN=0
WORKSPACE=1
AUTOSTART=ON
#EXPERIMENTAL: PREPARACION DEL DISCO DURO
PREPARE_HD="ON"
PREPARE_HDLINUX_VERSION="20100614b"
PREPARE_FSCACHE_VERSION="20130415"
PREPARE_HD_TYPE="default"
FORCE_HOME_SMB=OFF
#EXPERIMANTAL: PARA USAR TRITON
USE_TRITON="OFF"
#NXSERVER
USE_NXSERVER="ON"
#AUTO_REBOOT="4"
#EXPERIMENTAL : BITTORRENT
BT_START=OFF
VIRTUAL_IMAGES=(
AulasWindowsXP
)
#EXPERIMENTAL: CUPS
CUPS_START=OFF
CUPS_0_PRINTER=dell-soporte-color
CUPS_1_PRINTER=lj4200
CUPS_2_PRINTER=dell-sistemas-color
CUPS_3_PRINTER=biblioteca-epson-c2800
#EXPERIMENTAL: USER_VMPLAYER
USER_VMPLAYER=ON
#EXPERIMENTAL: USERDATA
USERDATA="ON"
USERDATA_SIZE="100G"
USERDATA_VERSION="20161005"
#########################
##   SESIONES
#########################
